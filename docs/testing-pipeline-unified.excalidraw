    {
      "type": "text",
      "id": "harden_sh_detail",
      "x": 850,
      "y": 416,
      "width": 510,
      "height": 110,
      "text": "Ralph-shaped outer loop  ·  mutation-kill per module\nreads: .quality/work.json  →  picks next failing module\ncalls: /playbook:qa-run engine  (the sophisticated part)\nplateau (3 identical failures) → mark BLOCKED, next\nuntil: tier floor held across all modules",
      "originalText": "Ralph-shaped outer loop  ·  mutation-kill per module\nreads: .quality/work.json  →  picks next failing module\ncalls: /playbook:qa-run engine  (the sophisticated part)\nplateau (3 identical failures) → mark BLOCKED, next\nuntil: tier floor held across all modules",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
