{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/shims/grok-shim.sh gateguard-fact-force.sh", "timeout": 15 },
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/shims/grok-shim.sh config-protection.sh", "timeout": 10 },
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/shims/grok-shim.sh careful-check.sh", "timeout": 10 },
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/shims/grok-shim.sh tmux-enforce.sh", "timeout": 10 },
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/shims/grok-shim.sh md-blocker.sh", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/shims/grok-shim.sh quality-gate.sh", "timeout": 60 },
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/shims/grok-shim.sh console-log-check.sh", "timeout": 10 },
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/shims/grok-shim.sh pr-url-logger.sh", "timeout": 10 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/session-start.sh", "timeout": 15 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash $HOME/.buildplaybook/hooks/session-end.sh", "timeout": 15 }
        ]
      }
    ]
  }
}
